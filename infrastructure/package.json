{
  "name": "codelens-infrastructure",
  "version": "0.1.0",
  "scripts": {
    "build":       "tsc",
    "watch":       "tsc -w",
    "deploy:dev":  "ENVIRONMENT=dev cdk deploy",
    "deploy:prod": "ENVIRONMENT=prod cdk deploy --require-approval broadening",
    "diff":        "cdk diff",
    "synth":       "cdk synth"
  },
  "dependencies": {
    "aws-cdk-lib":        "^2.170.0",
    "constructs":         "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "aws-cdk":     "^2.170.0",
    "typescript":  "^5.7.2"
  }
}
