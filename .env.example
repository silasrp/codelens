# ── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Embeddings ───────────────────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...

# ── Vector DB ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                       # leave blank for local Qdrant

# ── AWS (local dev — points at LocalStack) ───────────────────────────────────
